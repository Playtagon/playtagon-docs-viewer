# Set to true to protect the docs viewer with a server-side auth wall.
AUTH_ENABLED=false

# Supported values: google,github,oidc
AUTH_PROVIDERS=google,github,oidc

# Generate a long random value for real deployments.
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_TTL_HOURS=12

# Optional when the app is behind a proxy or deployed under a public URL.
# AUTH_BASE_URL=https://docs.example.com

# Access policy. A verified email must match either list.
AUTH_ALLOWED_EMAILS=alice@example.com,bob@example.com
AUTH_ALLOWED_DOMAINS=example.com

# Admin policy. Admins can open Settings and trigger rebuilds.
# If empty, every authenticated reader is treated as admin for backward compatibility.
AUTH_ADMIN_EMAILS=alice@example.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth. The app requests user:email and only accepts verified emails.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Generic OIDC
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile

# Optional build-time source overrides for hosted deployments.
# These let a Vercel project point the open-source viewer at a private docs repo
# without committing docs-viewer.config.json.
DOCS_VIEWER_APP_TITLE=Docs Viewer
DOCS_VIEWER_SOURCE_TYPE=github
DOCS_VIEWER_GITHUB_OWNER=your-org
DOCS_VIEWER_GITHUB_REPO=your-docs-repo
DOCS_VIEWER_GITHUB_BRANCH=main
DOCS_VIEWER_GITHUB_PATH=
DOCS_VIEWER_THEME_ACTIVE=default
DOCS_VIEWER_THEME_DIRECTORY=themes
# Optional full inline theme JSON. When set, it overrides THEME_ACTIVE/THEME_DIRECTORY.
# DOCS_VIEWER_THEME_JSON={"schema":"docs-viewer-theme/v1","id":"custom","name":"Custom","mode":"light","colors":{}}
# Use __empty__ for an intentional empty list, for example to scan the full vault.
DOCS_VIEWER_ROADMAP_INCLUDED_FOLDERS=
DOCS_VIEWER_ROADMAP_EXCLUDED_FOLDERS=
DOCS_VIEWER_ROADMAP_HIDE_UNDATED=false
DOCS_VIEWER_PLUGIN_ROADMAP_ENABLED=true
DOCS_VIEWER_IGNORED_FOLDERS=.git,.claude,.obsidian,.trash,node_modules,__pycache__,.github/workflows
